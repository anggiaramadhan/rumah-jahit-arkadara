---
---
<section id="location" class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div class="space-y-8">
        <div>
          <h2 class="text-sm font-bold tracking-widest text-arkadara-500 uppercase mb-3">Lokasi Kami</h2>
          <p class="text-3xl sm:text-4xl font-serif font-bold text-arkadara-900">Kunjungi Butik Arkadara di Cisauk</p>
        </div>
        
        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-arkadara-100 rounded-full flex items-center justify-center text-arkadara-600 flex-shrink-0">
               <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <div>
              <h4 class="font-bold text-arkadara-900 mb-1">Alamat</h4>
              <p class="text-arkadara-900/60">Cisauk, Kec. Cisauk, Kabupaten Tangerang, Banten</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-arkadara-100 rounded-full flex items-center justify-center text-arkadara-600 flex-shrink-0">
               <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div>
              <h4 class="font-bold text-arkadara-900 mb-1">Jam Operasional</h4>
              <p class="text-arkadara-900/60">Senin - Sabtu: 09.00 - 18.00 WIB</p>
              <p class="text-arkadara-900/60 italic text-sm">(Mohon buat janji temu sebelum datang)</p>
            </div>
          </div>
        </div>

        <a href="https://maps.google.com/?q=Cisauk+Tangerang" target="_blank" class="inline-flex items-center px-6 py-3 border-2 border-arkadara-600 text-arkadara-600 font-bold rounded-full hover:bg-arkadara-600 hover:text-white transition-all">
          Buka di Google Maps
        </a>
      </div>

      <div class="rounded-3xl overflow-hidden shadow-2xl h-[400px] border-8 border-arkadara-50 ring-1 ring-arkadara-100">
        <!-- Google Maps Embed Placeholder (Cisauk Area) -->
        <iframe 
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d15862.668541995804!2d106.6343516!3d-6.3204558!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e69fb208fa1a8f9%3A0x643c162cf08d3e23!2sCisauk%2C%20Tangerang%20Regency%2C%20Banten!5e0!3m2!1sen!2sid!4v1709770000000!5m2!1sen!2sid" 
          width="100%" 
          height="100%" 
          style="border:0;" 
          allowfullscreen="" 
          loading="lazy" 
          referrerpolicy="no-referrer-when-downgrade">
        </iframe>
      </div>
    </div>
  </div>
</section>
