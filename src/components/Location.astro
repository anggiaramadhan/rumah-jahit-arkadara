---
const locationName = "Rumah Jahit Arkadara";
const locationAddress =
  "Jl. Lkr. Selatan Jl. Golden Park II No.8B Blok H, Suradita, Kec. Cisauk, Kabupaten Tangerang, Banten 15343";
const googleMapsUrl =
  "https://www.google.com/maps/place/Rumah+Jahit+Arkadara,+Jl.+Lkr.+Selatan+Jl.+Golden+Park+II+No.8B+Blok+H,+Suradita,+Kec.+Cisauk,+Kabupaten+Tangerang,+Banten+15343/data=!4m2!3m1!1s0x2e69e5f8d7fcd421:0xa58cb9166e8e2bee!18m1!1e1";
const embedAddress = encodeURIComponent(`${locationName}, ${locationAddress}`);
---
<section id="location" class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div class="space-y-8">
        <div>
          <h2 class="text-sm font-bold tracking-widest text-arkadara-500 uppercase mb-3">Lokasi Kami</h2>
          <p class="text-3xl sm:text-4xl font-serif font-bold text-arkadara-900">Kunjungi {locationName} di Cisauk</p>
        </div>
        
        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-arkadara-100 rounded-full flex items-center justify-center text-arkadara-600 flex-shrink-0">
               <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <div>
              <h4 class="font-bold text-arkadara-900 mb-1">Alamat</h4>
              <p class="text-arkadara-900/60">{locationAddress}</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-arkadara-100 rounded-full flex items-center justify-center text-arkadara-600 flex-shrink-0">
               <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div>
              <h4 class="font-bold text-arkadara-900 mb-1">Jam Operasional</h4>
              <p class="text-arkadara-900/60">Senin - Sabtu: 09.00 - 18.00 WIB</p>
              <p class="text-arkadara-900/60 italic text-sm">(Mohon buat janji temu sebelum datang)</p>
            </div>
          </div>
        </div>

        <a href={googleMapsUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center px-6 py-3 border-2 border-arkadara-600 text-arkadara-600 font-bold rounded-full hover:bg-arkadara-600 hover:text-white transition-all">
          Buka di Google Maps
        </a>
      </div>

      <div class="rounded-3xl overflow-hidden shadow-2xl h-[400px] border-8 border-arkadara-50 ring-1 ring-arkadara-100">
        <!-- Google Maps Embed -->
        <iframe 
          src={`https://maps.google.com/maps?q=${embedAddress}&t=&z=17&ie=UTF8&iwloc=B&output=embed`}
          width="100%" 
          height="100%" 
          style="border:0;" 
          allowfullscreen="" 
          loading="lazy" 
          referrerpolicy="no-referrer-when-downgrade">
        </iframe>
      </div>
    </div>
  </div>
</section>
