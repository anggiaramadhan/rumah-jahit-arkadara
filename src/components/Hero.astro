---
---

<section
  id="hero"
  class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 overflow-hidden"
>
  <!-- Background Accents -->
  <div
    class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/4 w-[600px] h-[600px] bg-arkadara-100/50 rounded-full blur-3xl -z-10"
  >
  </div>
  <div
    class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/4 w-[400px] h-[400px] bg-arkadara-500/10 rounded-full blur-3xl -z-10"
  >
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-12 gap-12 items-center">
      <!-- Left Content (Wider for editorial feel) -->
      <div class="lg:col-span-7 space-y-10 max-w-2xl mx-auto lg:mx-0 z-10">
        <div
          class="inline-flex items-center space-x-3 opacity-0 animate-[fade-in-up_0.8s_ease-out_forwards]"
        >
          <span class="w-8 h-[1px] bg-arkadara-600"></span>
          <span
            class="text-arkadara-600 text-sm font-bold tracking-widest uppercase"
            >Boutique Tailoring</span
          >
        </div>

        <h1
          class="text-5xl sm:text-6xl lg:text-7xl font-serif font-regular leading-[1.1] text-arkadara-900 opacity-0 animate-[fade-in-up_0.8s_ease-out_0.2s_forwards]"
        >
          Wujudkan Busana <br />
          <span class="italic font-light text-arkadara-600">Impian Anda</span>
        </h1>

        <p
          class="text-lg sm:text-xl text-arkadara-900/60 leading-relaxed font-light max-w-lg opacity-0 animate-[fade-in-up_0.8s_ease-out_0.4s_forwards]"
        >
          Spesialis Kebaya, Dress, dan Busana Custom di Tangerang. Kami
          menghadirkan jahitan berkualitas dengan sentuhan personal untuk setiap
          momen berharga.
        </p>

        <div
          class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-6 opacity-0 animate-[fade-in-up_0.8s_ease-out_0.6s_forwards]"
        >
          <a
            href="https://wa.me/6282316610193"
            target="_blank"
            class="btn-primary group flex items-center space-x-3 !px-10 !py-4"
          >
            <span class="tracking-wide text-sm font-bold uppercase"
              >Konsultasi WA</span
            >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-4 h-4 group-hover:translate-x-1 transition-transform"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
            </svg>
          </a>
          <a
            href="#services"
            class="text-arkadara-900 font-medium hover:text-arkadara-600 transition-colors uppercase tracking-widest text-sm border-b border-arkadara-900/30 hover:border-arkadara-600 pb-1"
          >
            Eksplorasi
          </a>
        </div>
      </div>

      <!-- Right Image/Visuals (Asymmetrical) -->
      <div class="lg:col-span-5 relative mt-12 lg:mt-0">
        <!-- Main Image -->
        <div
          class="relative z-10 aspect-[3/4] rounded-t-full rounded-b-md overflow-hidden shadow-2xl origin-bottom animate-[reveal_1.2s_cubic-bezier(0.77,0,0.175,1)_forwards]"
        >
          <div
            class="w-full h-full bg-gradient-to-br from-arkadara-100 to-arkadara-500/30 flex items-center justify-center"
          >
            <span
              class="text-arkadara-900 font-serif text-3xl italic opacity-30 -rotate-90 origin-center tracking-widest"
              >Arkadara</span
            >
          </div>
        </div>

        <!-- Secondary decorative image -->
        <div
          class="absolute -bottom-12 -left-16 w-48 aspect-square rounded-full overflow-hidden shadow-xl border-8 border-arkadara-50 hidden md:block opacity-0 animate-[fade-in-up_1s_ease-out_1s_forwards]"
        >
          <div
            class="w-full h-full bg-gradient-to-tr from-arkadara-600 to-arkadara-900 flex items-center justify-center"
          >
            <span class="text-white text-xs tracking-widest uppercase"
              >Est. 2024</span
            >
          </div>
        </div>

        <!-- Decorative Text Circle -->
        <div
          class="absolute top-10 -right-12 w-32 h-32 animate-[spin_20s_linear_infinite] opacity-50 hidden lg:block"
        >
          <svg viewBox="0 0 100 100" class="w-full h-full">
            <path
              id="curve"
              fill="transparent"
              d="M 50, 50 m -40, 0 a 40,40 0 1,1 80,0 a 40,40 0 1,1 -80,0"
            ></path>
            <text
              class="text-[12px] uppercase tracking-[0.2em] fill-arkadara-900 font-bold"
              ><textPath href="#curve">PREMIUM CUSTOM TAILORING •</textPath>
            </text>
          </svg>
        </div>
      </div>
    </div>
  </div>
</section>
