---
<section id="hero" class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 overflow-hidden">
  <!-- Background Accents -->
  <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/4 w-[600px] h-[600px] bg-arkadara-100/50 rounded-full blur-3xl -z-10"></div>
  <div class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/4 w-[400px] h-[400px] bg-arkadara-500/10 rounded-full blur-3xl -z-10"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center lg:text-left">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div class="space-y-8 max-w-2xl mx-auto lg:mx-0">
        <div class="inline-flex items-center space-x-2 px-3 py-1 rounded-full bg-arkadara-100 text-arkadara-600 text-sm font-medium">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-arkadara-500 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-arkadara-600"></span>
          </span>
          <span>Buka Konsultasi: Online & Offline</span>
        </div>
        
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-serif font-bold leading-tight decoration-arkadara-500/30 underline decoration-4 underline-offset-8">
          Wujudkan Busana Impian Anda di <span class="text-arkadara-600">Rumah Jahit Arkadara</span>
        </h1>
        
        <p class="text-lg sm:text-xl text-arkadara-900/70 leading-relaxed font-light">
          Spesialis Kebaya, Dress, dan Busana Custom di Cisauk, Tangerang. Kami menghadirkan jahitan berkualitas dengan sentuhan personal untuk setiap momen berharga Anda.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4">
          <a href="https://wa.me/6282316611093?text=Halo%20Rumah%20Jahit%20Arkadara,%20saya%20ingin%20konsultasi%20jahit%20busana." target="_blank" class="btn-primary flex items-center space-x-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <span>Konsultasi Sekarang (WA)</span>
          </a>
          <a href="#services" class="px-8 py-3 text-arkadara-600 font-medium hover:bg-arkadara-100 rounded-full transition-colors">
            Lihat Layanan
          </a>
        </div>
      </div>

      <div class="relative">
        <div class="aspect-square rounded-2xl overflow-hidden shadow-2xl rotate-2 hover:rotate-0 transition-transform duration-500">
           <!-- Image Placeholder - Will be updated with actual visual -->
           <div class="w-full h-full bg-gradient-to-br from-arkadara-500 to-arkadara-900 flex items-center justify-center">
              <span class="text-white font-serif text-2xl italic opacity-50">Rumah Jahit Arkadara</span>
           </div>
        </div>
        <!-- Decorative Elements -->
        <div class="absolute -bottom-6 -left-6 bg-white p-4 rounded-xl shadow-xl hidden sm:block -rotate-3">
          <p class="text-arkadara-600 font-serif font-bold italic text-lg">"Terbaik di Cisauk"</p>
          <div class="flex text-yellow-500 mt-1">
            <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
