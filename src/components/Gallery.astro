---
---
<section id="gallery" class="py-24 bg-arkadara-50 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-sm font-bold tracking-widest text-arkadara-500 uppercase mb-3">Galeri Karya</h2>
      <p class="text-3xl sm:text-4xl font-serif font-bold text-arkadara-900 mb-6">Hasil Jahitan Terbaik Kami</p>
      <div class="h-1 w-20 bg-arkadara-500 mx-auto"></div>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <!-- Gallery Items with creative staggered layout -->
      <div class="space-y-4">
        <div class="aspect-[3/4] bg-arkadara-100 rounded-2xl overflow-hidden hover:scale-105 transition-transform duration-500 border-4 border-white shadow-md">
          <div class="w-full h-full bg-gradient-to-br from-arkadara-500/20 to-arkadara-900/20 flex items-center justify-center italic text-arkadara-900/40">Kebaya</div>
        </div>
        <div class="aspect-square bg-arkadara-100 rounded-2xl overflow-hidden hover:scale-105 transition-transform duration-500 border-4 border-white shadow-md">
           <div class="w-full h-full bg-gradient-to-br from-arkadara-600/20 to-arkadara-900/20 flex items-center justify-center italic text-arkadara-900/40">Detail</div>
        </div>
      </div>
      
      <div class="space-y-4 md:mt-12">
        <div class="aspect-square bg-arkadara-100 rounded-2xl overflow-hidden hover:scale-105 transition-transform duration-500 border-4 border-white shadow-md">
           <div class="w-full h-full bg-gradient-to-br from-arkadara-500/20 to-arkadara-900/20 flex items-center justify-center italic text-arkadara-900/40">Dress</div>
        </div>
        <div class="aspect-[3/4] bg-arkadara-100 rounded-2xl overflow-hidden hover:scale-105 transition-transform duration-500 border-4 border-white shadow-md">
           <div class="w-full h-full bg-gradient-to-br from-arkadara-600/20 to-arkadara-900/20 flex items-center justify-center italic text-arkadara-900/40">Fitting</div>
        </div>
      </div>

      <div class="space-y-4">
        <div class="aspect-[3/4] bg-arkadara-100 rounded-2xl overflow-hidden hover:scale-105 transition-transform duration-500 border-4 border-white shadow-md">
           <div class="w-full h-full bg-gradient-to-br from-arkadara-500/20 to-arkadara-900/20 flex items-center justify-center italic text-arkadara-900/40">Pesta</div>
        </div>
        <div class="aspect-square bg-arkadara-100 rounded-2xl overflow-hidden hover:scale-105 transition-transform duration-500 border-4 border-white shadow-md">
           <div class="w-full h-full bg-gradient-to-br from-arkadara-600/20 to-arkadara-900/20 flex items-center justify-center italic text-arkadara-900/40">Bahan</div>
        </div>
      </div>

      <div class="space-y-4 md:mt-12">
        <div class="aspect-square bg-arkadara-100 rounded-2xl overflow-hidden hover:scale-105 transition-transform duration-500 border-4 border-white shadow-md">
           <div class="w-full h-full bg-gradient-to-br from-arkadara-500/20 to-arkadara-900/20 flex items-center justify-center italic text-arkadara-900/40">Sarimbit</div>
        </div>
        <div class="aspect-[3/4] bg-arkadara-100 rounded-2xl overflow-hidden hover:scale-105 transition-transform duration-500 border-4 border-white shadow-md">
           <div class="w-full h-full bg-gradient-to-br from-arkadara-600/20 to-arkadara-900/20 flex items-center justify-center italic text-arkadara-900/40">Wisuda</div>
        </div>
      </div>
    </div>
    
    <div class="mt-16 text-center">
      <p class="text-arkadara-900/70 mb-6">Lihat koleksi lengkap kami di Instagram</p>
      <a href="https://instagram.com/rumahjahit_arkadara" target="_blank" class="inline-flex items-center space-x-2 text-arkadara-600 font-bold hover:underline">
        <span>@rumahjahit_arkadara</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
      </a>
    </div>
  </div>
</section>
