---
const services = [
  {
    title: 'Custom Dress & Kebaya',
    description: 'Jahitan eksklusif untuk wisuda, lamaran, dan pernikahan dengan detail yang presisi.',
    icon: '✨',
  },
  {
    title: 'Seragam Keluarga',
    description: 'Sarimbit atau seragam pesta untuk seluruh anggota keluarga dengan desain serasi.',
    icon: '🧵',
  },
  {
    title: 'Jahit Harian & Permak',
    description: 'Layanan jahit untuk busana sehari-hari maupun perbaikan agar pas di badan.',
    icon: '🪡',
  },
];
---
<section id="services" class="py-24 bg-white relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-sm font-bold tracking-widest text-arkadara-500 uppercase mb-3">Layanan Kami</h2>
      <p class="text-3xl sm:text-4xl font-serif font-bold text-arkadara-900 mb-6">Expertise dalam Seni Menjahit</p>
      <div class="h-1 w-20 bg-arkadara-500 mx-auto"></div>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {services.map((service) => (
        <div class="group p-8 rounded-2xl bg-arkadara-50 border border-arkadara-100 hover:border-arkadara-500 transition-all duration-300 hover:shadow-xl">
          <div class="text-4xl mb-6 group-hover:scale-110 transition-transform duration-300">{service.icon}</div>
          <h3 class="text-xl font-serif font-bold text-arkadara-900 mb-4">{service.title}</h3>
          <p class="text-arkadara-900/70 leading-relaxed font-light">{service.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
