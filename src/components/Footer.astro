---
const currentYear = new Date().getFullYear();
---

<footer class="bg-arkadara-900 text-white pt-20 pb-10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-3 gap-12 mb-16">
      <!-- Brand -->
      <div class="space-y-6">
        <h3 class="text-2xl font-serif font-bold">Arkadara</h3>
        <p class="text-white/60 leading-relaxed font-light">
          Penjahit khusus wanita dan keluarga dengan kualitas butik. Kami
          melayani sepenuh hati untuk mewujudkan busana terbaik Anda.
        </p>
        <div class="flex space-x-4">
          <a
            href="https://instagram.com/rumahjahitarkadara"
            class="w-10 h-10 rounded-full border border-white/20 flex items-center justify-center hover:bg-white hover:text-arkadara-900 transition-all"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><rect width="20" height="20" x="2" y="2" rx="5" ry="5"
              ></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
              ></path><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line>
            </svg>
          </a>
          <a
            href="https://wa.me/6282316611093"
            class="w-10 h-10 rounded-full border border-white/20 flex items-center justify-center hover:bg-white hover:text-arkadara-900 transition-all"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
              ></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Links -->
      <div class="space-y-6">
        <h4
          class="font-bold text-lg uppercase tracking-wider text-arkadara-500"
        >
          Navigasi
        </h4>
        <ul class="space-y-4">
          <li>
            <a
              href="#hero"
              class="text-white/60 hover:text-white transition-colors"
              >Beranda</a
            >
          </li>
          <li>
            <a
              href="#services"
              class="text-white/60 hover:text-white transition-colors"
              >Layanan</a
            >
          </li>
          <li>
            <a
              href="#process"
              class="text-white/60 hover:text-white transition-colors"
              >Cara Pesan</a
            >
          </li>
          <li>
            <a
              href="#location"
              class="text-white/60 hover:text-white transition-colors">Lokasi</a
            >
          </li>
        </ul>
      </div>

      <!-- Contact -->
      <div class="space-y-6">
        <h4
          class="font-bold text-lg uppercase tracking-wider text-arkadara-500"
        >
          Hubungi Kami
        </h4>
        <div class="space-y-4 text-white/60">
          <p>WA: 082316610193</p>
          <p>Email: nurul.hardoyo@gmail.com</p>
          <p>Lokasi: Cisauk, Tangerang</p>
        </div>
      </div>
    </div>

    <div
      class="pt-10 border-t border-white/10 text-center text-white/40 text-sm"
    >
      <p>&copy; {currentYear} Rumah Jahit Arkadara. All Rights Reserved.</p>
    </div>
  </div>
</footer>
